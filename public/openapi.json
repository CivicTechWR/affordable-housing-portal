              },
              "name": { "type": "string" },
              "role": {
                "type": "string",
                "enum": ["admin", "partner", "user"]
              },
              "inviteUrl": { "type": "string", "format": "uri" }
            },
            "required": ["id", "email", "name", "role", "inviteUrl"],
            "additionalProperties": false
