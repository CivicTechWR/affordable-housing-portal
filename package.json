    "date-fns": "^4.1.0",
    "maplibre-gl": "^5.21.1",
    "next": "^16.2.2",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.8.0",
