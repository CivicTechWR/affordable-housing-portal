{
  "name": "affordable-housing-platform-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:secrets": "infisical run --env=dev -- next dev",
    "build": "next build",
    "build:secrets": "infisical run --env=dev -- next build",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:secrets": "infisical run --env=dev -- drizzle-kit migrate",
    "db:seed": "node --env-file-if-exists=.env.local --experimental-strip-types db/seed.ts",
    "db:seed:secrets": "infisical run --env=dev -- node --experimental-strip-types db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "start": "next start",
    "start:secrets": "infisical run --env=dev -- next start",
    "lint": "oxlint . -c .oxlintrc.json",
    "lint:fix": "oxlint . -c .oxlintrc.json --fix",
    "format": "oxfmt . -c .oxfmtrc.json",
    "format:check": "oxfmt --check . -c .oxfmtrc.json",
    "prepare": "husky",
    "test": "jest",
    "test:unit": "jest --testPathPattern=\\.unit\\.test\\.",
    "test:integration": "jest --testPathPattern=\\.integration\\.test\\.",
    "openapi:generate": "node --import=tsx ./scripts/openapi.ts generate",
    "openapi:validate": "node --import=tsx ./scripts/openapi.ts validate"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@vis.gl/react-maplibre": "^8.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "maplibre-gl": "^5.21.1",
    "next": "^16.2.2",
    "next-auth": "5.0.0-beta.31",
    "next-rest-framework": "^6.1.1",
    "nuqs": "^2.8.9",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.8.0",
    "resend": "^6.11.0",
    "sass": "^1.98.0",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.0",
    "drizzle-kit": "^0.31.10",
    "gitleaks-secret-scanner": "^2.1.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^15.4.3",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "gitleaks-secret-scanner": {
      "tar": "^7.5.13"
    },
    "next-rest-framework": {
      "lodash": "^4.18.1",
      "qs": "^6.15.1"
    }
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
